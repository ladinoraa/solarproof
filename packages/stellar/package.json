{
  "name": "@solarproof/stellar",
  "version": "1.0.0",
  "description": "Shared Stellar/Soroban utilities for SolarProof",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": { "@stellar/stellar-sdk": "^13.1.0" },
  "devDependencies": { "tsup": "^8.3.5", "typescript": "^5.6.3" }
}
