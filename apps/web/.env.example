# Supabase — copy from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stellar / Soroban network
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Deployed contract IDs (set after running deploy-contracts workflow)
NEXT_PUBLIC_ENERGY_TOKEN_ID=
NEXT_PUBLIC_AUDIT_REGISTRY_ID=
NEXT_PUBLIC_COMMUNITY_GOVERNANCE_ID=

# Minter keypair — choose one:
# Production: load from AWS Secrets Manager (recommended)
MINTER_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:solarproof/minter-key
# Set during the 24-h grace window after rotation
# MINTER_PREVIOUS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:solarproof/minter-key-prev
AWS_REGION=us-east-1
# Local dev only (ignored when MINTER_SECRET_ARN is set)
MINTER_SECRET_KEY=

# Upstash Redis (optional — caching layer for certificate queries)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
